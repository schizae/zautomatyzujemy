# ============================================================
# SUPABASE
# Znajdziesz te wartości w: Supabase Dashboard → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-key

# Klucz service_role — TYLKO po stronie serwera, nigdy nie eksponuj w przeglądarce
# Używany przez: webhook n8n (/api/blog/publish), skrypty do embeddings
SUPABASE_SERVICE_ROLE_KEY=twoj-service-role-key

# ============================================================
# GOOGLE GEMINI — do generowania embeddings i odpowiedzi chatbota
# Wygeneruj klucz w: https://aistudio.google.com/app/apikey
# ============================================================
GOOGLE_GENERATIVE_AI_API_KEY=twoj-gemini-api-key

# ============================================================
# N8N — integracja z automatyzacją
# ============================================================
# Sekretny token weryfikujący żądania przychodzące z n8n (POST /api/blog/publish)
N8N_WEBHOOK_SECRET=wymysl-dlugi-losowy-string

# URL webhooka w n8n, na który chatbot wyśle zebrany e-mail klienta
N8N_LEAD_WEBHOOK_URL=https://twoja-instancja.n8n.cloud/webhook/leads

# ============================================================
# ADMIN PANEL
# ============================================================
# Hasło do panelu administracyjnego — wygeneruj losowy string:
# openssl rand -hex 32
ADMIN_SECRET=twoje-haslo-administratora

# ============================================================
# APLIKACJA
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
